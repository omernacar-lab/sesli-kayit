# ============================================
# SESLİ KAYIT - API ANAHTARLARI
# ============================================
# Bu dosyayı .env.local olarak kaydet
# API key'lerini aşağıya yapıştır
# ============================================

# OpenAI (Whisper transkripsiyon için)
OPENAI_API_KEY=sk-...buraya-yapistir...

# Anthropic (Claude parse için)
ANTHROPIC_API_KEY=sk-ant-...buraya-yapistir...

# Google Sheets
# Service account JSON dosyasındaki değerleri buraya koy:
GOOGLE_SERVICE_ACCOUNT_EMAIL=sesli-kayit-bot@proje-adi.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...JSON dosyasındaki private_key değeri...\n-----END PRIVATE KEY-----\n"

# Ablanın Google Sheet ID'si (URL'den al)
# https://docs.google.com/spreadsheets/d/BURASI_SHEET_ID/edit
GOOGLE_SHEET_ID=1KyRHSWehfftwS1EMhM71CmyTZKKGarltDnbjuBwLRZo
